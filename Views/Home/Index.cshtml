@{
    ViewBag.Title = "BlindMatch PAS";
    Layout = "_Layout";
}

<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:60vh; text-align:center;">

    <p style="font-family:var(--font-mono); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--grey-400); margin-bottom:1rem;">
        PUSL2020 — Project Approval System
    </p>

    <h1 style="font-size:3rem; font-weight:600; letter-spacing:-0.04em; line-height:1.1; margin-bottom:1rem;">
        Blind<span style="color:var(--grey-400);">Match</span>
    </h1>

    <p style="max-width:420px; color:var(--grey-600); font-size:15px; line-height:1.7; margin-bottom:2rem;">
        A fair, bias-free project matching platform. Student identities remain hidden until a supervisor confirms their match.
    </p>

    <!-- BUTTONS -->
    <div style="display:flex; gap:0.75rem;">
        <a href="/Account/Login" class="btn btn-primary">Sign In</a>
        <a href="/Account/Register" class="btn">Request Account</a>
    </div>

    <!-- INFO GRID -->
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--grey-200); border:var(--border); margin-top:4rem; width:100%; max-width:600px;">

        <div style="background:var(--white); padding:1.5rem;">
            <div style="font-family:var(--font-mono); font-size:11px; text-transform:uppercase; letter-spacing:0.06em; color:var(--grey-400); margin-bottom:0.4rem;">
                Student
            </div>
            <div style="font-size:14px; color:var(--grey-600);">
                Submit proposals & track status
            </div>
        </div>

        <div style="background:var(--white); padding:1.5rem;">
            <div style="font-family:var(--font-mono); font-size:11px; text-transform:uppercase; letter-spacing:0.06em; color:var(--grey-400); margin-bottom:0.4rem;">
                Supervisor
            </div>
            <div style="font-size:14px; color:var(--grey-600);">
                Blind review & match projects
            </div>
        </div>

        <div style="background:var(--white); padding:1.5rem;">
            <div style="font-family:var(--font-mono); font-size:11px; text-transform:uppercase; letter-spacing:0.06em; color:var(--grey-400); margin-bottom:0.4rem;">
                Admin
            </div>
            <div style="font-size:14px; color:var(--grey-600);">
                Oversee all allocations
            </div>
        </div>

    </div>
</div>