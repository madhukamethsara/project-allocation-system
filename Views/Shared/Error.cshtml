@{
    ViewBag.Title = "Error";
    Layout = "_Layout";
}

<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:50vh; text-align:center;">
    <p style="font-family:var(--font-mono); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--grey-400); margin-bottom:0.75rem;">500 — Server Error</p>
    <h1 style="font-size:2rem; font-weight:600; letter-spacing:-0.03em; margin-bottom:1rem;">Something went wrong</h1>
    <p style="color:var(--grey-600); font-size:14px; margin-bottom:2rem;">An unexpected error occurred. Please try again or contact support.</p>
    <a href="/" class="btn btn-primary">Return Home</a>
</div>
