@model List<BlindMatchPAS.Models.ResearchArea>
@{ ViewBag.Title = "Research Areas"; }

<div class="page-header">
    <h1>Research Areas</h1>
    <p>Manage the categories used to classify project proposals</p>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:2rem; align-items:start; max-width:800px;">
    <div>
        <div class="section-label">Current Areas (@Model.Count)</div>

        @if (!Model.Any())
        {
            <p style="font-size:14px; color:var(--grey-400);">No research areas defined yet.</p>
        }
        else
        {
            @foreach (var a in Model)
            {
                <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:var(--border);">
                    <span style="font-size:14px;">@a.Name</span>
                    <form method="post" action="/Admin/DeleteResearchArea/@a.Id" onsubmit="return confirm('Delete this research area?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                    </form>
                </div>
            }
        }
    </div>

    <div>
        <div class="section-label">Add New Area</div>
        <form method="post" action="/Admin/AddResearchArea">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Area Name</label>
                <input class="form-control" name="name" placeholder="e.g. Blockchain Technology" required />
            </div>
            <button type="submit" class="btn btn-primary">Add Area</button>
        </form>
    </div>
</div>
