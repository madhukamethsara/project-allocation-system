@model BlindMatchPAS.Models.ViewModels.AdminUserManagementPageViewModel
@{
    ViewBag.Title = "User Management";
}

<div class="page-header">
    <h1>User Management</h1>
    <p>Add students, add supervisors, and control login access in one place.</p>
</div>

@if (TempData["Success"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
else if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-error">@errorMessage</div>
}

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-number">@Model.Users.Count</div>
        <div class="stat-label">Total Users</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">@Model.Users.Count(u => u.Role == BlindMatchPAS.Models.UserRole.Student)</div>
        <div class="stat-label">Students</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">@Model.Users.Count(u => u.Role == BlindMatchPAS.Models.UserRole.Supervisor)</div>
        <div class="stat-label">Supervisors</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">@Model.Users.Count(u => u.IsActive)</div>
        <div class="stat-label">Active Accounts</div>
    </div>
</div>

<div class="user-mgmt-grid">
    <!-- Add Student -->
    <div class="panel-card">
        <div class="section-label">Add Student</div>

        <form asp-action="AddStudent" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">Full Name</label>
                <input class="form-control" name="Name" placeholder="Student full name" required />
            </div>

            <div class="form-group">
                <label class="form-label">Email</label>
                <input class="form-control" name="Email" type="email" placeholder="student@nsbm.lk" required />
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <input class="form-control" name="Password" type="password" placeholder="Minimum 6 characters" required />
            </div>

            <div class="form-group">
                <label class="form-label">Batch</label>
                <select class="form-control" name="Batch" required>
                    <option value="">— Select batch —</option>
                    @foreach (var batch in Model.Batches)
                    {
                        <option value="@batch">@batch</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Registration Number</label>
                <input class="form-control" name="RegistrationNumber" placeholder="SE241001" required />
            </div>

            <div class="form-group checkbox-row">
                <input type="hidden" name="IsActive" value="false" />
                <input type="checkbox" id="studentActive" name="IsActive" value="true" checked />
                <label for="studentActive">Active account</label>
            </div>

            <button type="submit" class="btn">Add Student</button>
        </form>
    </div>

    <!-- Add Supervisor -->
    <div class="panel-card">
        <div class="section-label">Add Supervisor</div>

        <form asp-action="AddSupervisor" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">Full Name</label>
                <input class="form-control" name="Name" placeholder="Supervisor full name" required />
            </div>

            <div class="form-group">
                <label class="form-label">Email</label>
                <input class="form-control" name="Email" type="email" placeholder="supervisor@nsbm.lk" required />
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <input class="form-control" name="Password" type="password" placeholder="Minimum 6 characters" required />
            </div>

            <div class="form-group">
                <label class="form-label">Department</label>
                <input class="form-control" name="Department" placeholder="Computing" required />
            </div>

            <div class="form-group">
                <label class="form-label">Research Area</label>
                <select class="form-control" name="ResearchAreaId" required>
                    <option value="">— Select research area —</option>
                    @foreach (var area in Model.ResearchAreas)
                    {
                        <option value="@area.Id">@area.Name</option>
                    }
                </select>
            </div>

            <div class="form-group checkbox-row">
                <input type="hidden" name="IsActive" value="false" />
                <input type="checkbox" id="supervisorActive" name="IsActive" value="true" checked />
                <label for="supervisorActive">Active account</label>
            </div>

            <button type="submit" class="btn">Add Supervisor</button>
        </form>
    </div>
</div>

<div class="section-label">Filters</div>

<div class="filter-bar">
    <div class="filter-group">
        <label class="form-label">Search Name / Email</label>
        <input
            type="text"
            id="searchFilter"
            class="form-control"
            placeholder="Search by name or email" />
    </div>

    <div class="filter-group">
        <label class="form-label">Batch</label>
        <select id="batchFilter" class="form-control">
            <option value="">All Batches</option>
            @foreach (var b in Model.Batches)
            {
                <option value="@b">@b</option>
            }
        </select>
    </div>

    <div class="filter-group">
        <label class="form-label">Role</label>
        <select id="roleFilter" class="form-control">
            <option value="">All Roles</option>
            <option value="Student">Student</option>
            <option value="Supervisor">Supervisor</option>
            <option value="Admin">Admin</option>
        </select>
    </div>

    <div class="filter-group">
        <label class="form-label">Status</label>
        <select id="statusFilter" class="form-control">
            <option value="">All Status</option>
            <option value="Active">Active</option>
            <option value="Disabled">Disabled</option>
        </select>
    </div>
</div>

<div class="filter-actions-row">
    <button type="button" class="btn btn-light" id="resetFilters">Reset Filters</button>
</div>

<div class="section-label">Access Control</div>

@if (!Model.Users.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">◻</div>
        <h3>No users found</h3>
        <p>Users will appear here once students and supervisors are added.</p>
    </div>
}
else
{
    <div class="table-wrap">
        <table id="usersTable">
            <thead>
                <tr>
                    <th>Role</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Batch</th>
                    <th>Department</th>
                    <th>Research Area</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Users)
                {
                    <tr
                        data-role="@u.Role"
                        data-name="@u.Name"
                        data-email="@u.Email"
                        data-batch="@(u.Batch ?? "")"
                        data-department="@(u.Department ?? "")"
                        data-researcharea="@(u.ResearchArea?.Name ?? "")"
                        data-status="@(u.IsActive ? "Active" : "Disabled")">
                        <td>
                            <span class="badge badge-pending" style="font-size:10px;">@u.Role</span>
                        </td>
                        <td style="font-weight:500;">@u.Name</td>
                        <td style="font-size:12px; color:var(--grey-400);">@u.Email</td>
                        <td>@(string.IsNullOrWhiteSpace(u.Batch) ? "—" : u.Batch)</td>
                        <td>@(string.IsNullOrWhiteSpace(u.Department) ? "—" : u.Department)</td>
                        <td>@(u.ResearchArea?.Name ?? "—")</td>
                        <td>
                            @if (u.IsActive)
                            {
                                <span class="badge" style="background:#000; color:#fff;">Active</span>
                            }
                            else
                            {
                                <span class="badge" style="background:#fff; color:#000; border:1px solid #000;">Disabled</span>
                            }
                        </td>
                        <td>
                            <form asp-action="ToggleUserStatus" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.Id" />
                                <button type="submit" class="mini-btn">
                                    @(u.IsActive ? "Disable" : "Enable")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div id="noResultsMessage" class="empty-state" style="display:none; margin-top:1rem;">
        <div class="empty-state-icon">◻</div>
        <h3>No matching users</h3>
        <p>Try changing the search or filter values.</p>
    </div>
}

<script>
    setTimeout(() => {
        const alertBox = document.querySelector('.alert');
        if (alertBox) {
            alertBox.style.display = 'none';
        }
    }, 3000);

    const searchFilter = document.getElementById('searchFilter');
    const batchFilter = document.getElementById('batchFilter');
    const roleFilter = document.getElementById('roleFilter');
    const statusFilter = document.getElementById('statusFilter');
    const resetFiltersBtn = document.getElementById('resetFilters');
    const userRows = document.querySelectorAll('#usersTable tbody tr');
    const noResultsMessage = document.getElementById('noResultsMessage');

    function applyFilters() {
        const searchValue = (searchFilter?.value || '').toLowerCase().trim();
        const batchValue = batchFilter?.value || '';
        const roleValue = roleFilter?.value || '';
        const statusValue = statusFilter?.value || '';

        let visibleCount = 0;

        userRows.forEach(row => {
            const name = (row.dataset.name || '').toLowerCase();
            const email = (row.dataset.email || '').toLowerCase();
            const batch = row.dataset.batch || '';
            const role = row.dataset.role || '';
            const status = row.dataset.status || '';

            const matchesSearch =
                !searchValue ||
                name.includes(searchValue) ||
                email.includes(searchValue);

            const matchesBatch =
                !batchValue || batch === batchValue;

            const matchesRole =
                !roleValue || role === roleValue;

            const matchesStatus =
                !statusValue || status === statusValue;

            const shouldShow =
                matchesSearch &&
                matchesBatch &&
                matchesRole &&
                matchesStatus;

            row.style.display = shouldShow ? '' : 'none';

            if (shouldShow) {
                visibleCount++;
            }
        });

        if (noResultsMessage) {
            noResultsMessage.style.display = visibleCount === 0 ? 'block' : 'none';
        }
    }

    searchFilter?.addEventListener('input', applyFilters);
    batchFilter?.addEventListener('change', applyFilters);
    roleFilter?.addEventListener('change', applyFilters);
    statusFilter?.addEventListener('change', applyFilters);

    resetFiltersBtn?.addEventListener('click', () => {
        if (searchFilter) searchFilter.value = '';
        if (batchFilter) batchFilter.value = '';
        if (roleFilter) roleFilter.value = '';
        if (statusFilter) statusFilter.value = '';
        applyFilters();
    });
</script>

<style>
    .user-mgmt-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin: 1.5rem 0 2rem;
    }

    .panel-card {
        border: 1px solid #111;
        background: #fff;
        padding: 1rem;
    }

    .section-label {
        margin: 1.25rem 0 0.75rem;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #111;
    }

    .checkbox-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0.75rem 0 1rem;
        font-size: 13px;
        color: #111;
    }

    .filter-bar {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        align-items: end;
        margin: 0 0 1rem;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
    }

    .filter-actions-row {
        margin-bottom: 1.5rem;
    }

    .mini-btn {
        background: #000;
        color: #fff;
        border: 1px solid #000;
        padding: 6px 10px;
        font-size: 12px;
        cursor: pointer;
    }

    .mini-btn:hover {
        background: #fff;
        color: #000;
    }

    .btn-light {
        background: #fff;
        color: #000;
        border: 1px solid #000;
        padding: 10px 16px;
        text-decoration: none;
        font-size: 13px;
        cursor: pointer;
    }

    .btn-light:hover {
        background: #000;
        color: #fff;
    }

    @@media (max-width: 900px) {
        .user-mgmt-grid {
            grid-template-columns: 1fr;
        }

        .filter-bar {
            grid-template-columns: 1fr;
        }
    }
</style>