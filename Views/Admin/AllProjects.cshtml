@model List<BlindMatchPAS.Models.Project>
@{ ViewBag.Title = "All Projects"; }

<div class="page-header">
    <h1>All Projects</h1>
    <p>Complete list of all project proposals in the system</p>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">◻</div>
        <h3>No projects submitted yet</h3>
    </div>
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Student</th>
                    <th>Research Area</th>
                    <th>Status</th>
                    <th>Supervisor</th>
                    <th>Submitted</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td style="font-weight:500; max-width:220px;">@p.Title</td>
                        <td>
                            <div>@p.Student?.Name</div>
                            <div style="font-size:12px; color:var(--grey-400);">@p.Student?.Email</div>
                        </td>
                        <td>@p.ResearchArea?.Name</td>
                        <td>
                            @{
                                var cls = p.Status switch {
                                    BlindMatchPAS.Models.ProjectStatus.Matched => "badge-matched",
                                    BlindMatchPAS.Models.ProjectStatus.UnderReview => "badge-review",
                                    BlindMatchPAS.Models.ProjectStatus.Withdrawn => "badge-withdrawn",
                                    _ => "badge-pending"
                                };
                            }
                            <span class="badge @cls">@p.Status</span>
                        </td>
                        <td style="font-size:13px;">
                            @(p.Supervisor?.Name ?? "—")
                        </td>
                        <td style="font-size:12px; color:var(--grey-400); font-family:var(--font-mono);">
                            @p.CreatedAt.ToString("dd MMM yyyy")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}